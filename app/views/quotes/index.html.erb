<%# app/views/quotes/index.html.erb %>
<h1>Quotes</h1>

<main class="container">
  <%= turbo_frame_tag "first_turbo_frame" do %>
    <div class="header">
      <%= link_to "New Quote", 
                  new_quote_path,
                  data: { turbo_frame: "new_quote" },
                  class: "btn btn-primary" %>
    </div>
  <% end %>

  <%= turbo_frame_tag "new_quote" do %>
  <% end %>

  <%= turbo_frame_tag "quotes" %>
  <%= render @quotes %>
  
</main>